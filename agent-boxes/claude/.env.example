# Tailscale auth key — MUST be reusable.
# Generate at: admin.tailscale.com → Settings → Keys → Generate auth key
# Check "Reusable" so the container can re-authenticate after rebuilds.
TS_AUTHKEY=tskey-auth-...

# Your Mac user UID — run: id -u
# Used so files written by the container are owned by your Mac user on the host.
# GID is hardcoded to 1000 in the image (macOS GIDs conflict with Ubuntu system GIDs).
UID=501

# Anthropic API key — only required if NOT using the 'claude login' browser flow.
# ANTHROPIC_API_KEY=sk-ant-...
