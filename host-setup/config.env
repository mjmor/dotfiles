# ── Colima VM resources ────────────────────────────────────────────────────
# vCPUs allocated to the Colima VM
COLIMA_CPUS=6

# RAM in GiB allocated to the Colima VM
COLIMA_MEMORY=8

# Disk size in GiB for the Colima VM
COLIMA_DISK=100

# ── Minikube resources (runs inside Colima VM) ─────────────────────────────
# RAM for minikube in MiB
MINIKUBE_MEMORY=4096

# CPUs for minikube
MINIKUBE_CPUS=2

# ── Minikube addons ────────────────────────────────────────────────────────
# Space-separated list of addons to enable
MINIKUBE_ADDONS="ingress metrics-server storage-provisioner registry"

# ── Ollama models ──────────────────────────────────────────────────────────
# LOCAL: smaller models for on-device inference; pulled on every bootstrap
OLLAMA_MODELS_LOCAL="nemotron-3-nano:4b gemma4:e4b"

# CLOUD: larger models intended for cloud-offload inference
OLLAMA_MODELS_CLOUD="gemma4:31b-cloud"
